# ═══════════════════════════════════════════════════════════════════════════
# n-assistant-core — Environment Variables
# Copy this file to .env and adjust values for your local setup.
# ═══════════════════════════════════════════════════════════════════════════

# ── Inference provider ─────────────────────────────────────────────────────
INFERENCE_PROVIDER=ollama
INFERENCE_MODEL=hermes3
INFERENCE_BASE_URL=http://localhost:11434/v1
# For local Ollama this value is unused.
# To use OpenAI: set BASE_URL=https://api.openai.com/v1 and put your key here.
INFERENCE_API_KEY=ollama

# ── Vector DB (Qdrant) ────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6353

# ── Cache / Broker (Redis) ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6399/0

# ── Harvester secrets (Chặng 0) ───────────────────────────────────────────
# X (Twitter) session cookie. Referenced from scraper_config.yaml as
# ${X_AUTH_TOKEN}. NEVER commit a real token — keep it only in .env.
X_AUTH_TOKEN=YOUR_AUTH_TOKEN_HERE
X_CT0_TOKEN=YOUR_CT0_TOKEN_HERE

# ── Application ───────────────────────────────────────────────────────────
# APP_NAME=N Assistant — Core API (Open-Source)
# APP_VERSION=0.1.0
# DEBUG=false
# LOG_LEVEL=INFO
